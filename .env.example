# corridor-in-a-box — example environment
#
# The library packages take their configuration as constructor OPTIONS, not from
# process.env (so they stay embeddable). These variables are the convention for
# the thin deployment layer you write around them — your service entrypoint reads
# these and wires StellarSettlementSubmitter / PostgresIdempotencyStore / createService.
#
# Copy to .env.local and fill in. NEVER commit a real secret. The signing seed
# below is for testnet/dev ONLY — in production implement an ExternalSigner over a
# KMS/HSM so the seed never enters the process (see docs/key-management.md).

# --- Stellar settlement leg ---
# https://horizon-testnet.stellar.org  (testnet)  |  https://horizon.stellar.org  (public)
HORIZON_URL=https://horizon-testnet.stellar.org
# Dev/testnet only. Production: leave unset and back the submitter with an ExternalSigner.
CORRIDOR_SIGNER_SECRET=

# --- examples/run-testnet.ts (pnpm testnet) ---
# Path to the corridor manifest to run. Defaults to corridors/reference.corridor.yaml.
MANIFEST=corridors/reference.corridor.yaml
# Set to move real money on a `network: public` (mainnet) corridor. Refuses to
# run one otherwise.
CORRIDOR_ALLOW_MAINNET=

# --- Durable idempotency store ---
# Any Postgres connection string; the store needs a `pg.Pool`-compatible client.
DATABASE_URL=postgres://corridor:corridor@localhost:5432/corridor

# --- Service (@corridor/service, launched via examples/run-service.ts / pnpm serve) ---
PORT=8080
# Comma-separated bearer keys accepted by the API. Empty = no auth (dev only).
CORRIDOR_API_KEYS=
# Token-bucket rate limit (per client). Omit to disable.
CORRIDOR_RATELIMIT_CAPACITY=20
CORRIDOR_RATELIMIT_REFILL_PER_SEC=5
# Directory to load corridor manifests from. Defaults to corridors/.
CORRIDORS_DIR=corridors

# --- web/ showcase app (optional) ---
# Point the "Run a payment" page at a running @corridor/service instead of the
# in-process simulation. Unset = use the local simulation.
CORRIDOR_SERVICE_URL=

# --- Integration test (tests/integration, opt-in) ---
# Set these to run the adapter against a real SEP-31 server. Unset = the
# integration suite is skipped.
#
# Known-good public values — the SDF test anchor on testnet, verified
# 2026-07-12 (SEP-10 auth, firm SEP-38 quote, SEP-12 status, all green):
#   ANCHOR_HOME_DOMAIN=testanchor.stellar.org
#   ANCHOR_SEP31_TRANSFER_SERVER=https://testanchor.stellar.org/sep31
#   ANCHOR_SEP31_QUOTE_SERVER=https://testanchor.stellar.org/sep38
#   ANCHOR_SEP31_WEB_AUTH=https://testanchor.stellar.org/auth
#   ANCHOR_SEP31_KYC_SERVER=https://testanchor.stellar.org/sep12
#   ANCHOR_ASSET_ISSUER=GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5
#   ANCHOR_DEST_ASSET=iso4217:USD
# plus CORRIDOR_SIGNER_SECRET above set to any funded testnet key
# (https://friendbot.stellar.org?addr=G...) so SEP-10 auth can run.
ANCHOR_SEP31_TRANSFER_SERVER=
ANCHOR_SEP31_QUOTE_SERVER=
ANCHOR_SEP31_WEB_AUTH=
ANCHOR_SEP31_KYC_SERVER=
ANCHOR_HOME_DOMAIN=
# The anchor's issuing account for the bridge asset (SEP-38 sell side) and the
# off-chain asset to quote into. Defaults: GTEST / iso4217:USD.
ANCHOR_ASSET_ISSUER=
ANCHOR_DEST_ASSET=
