{
  "name": "corridor-in-a-box",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Open, manifest-driven engine for Stellar SEP-31 cross-border corridors. A corridor is configuration, not code.",
  "license": "Apache-2.0",
  "author": "ezedike-evan <210902543@live.unilag.edu.ng>",
  "maintainers": [
    "ezedike-evan <210902543@live.unilag.edu.ng>"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ezedike-evan/corridor-in-a-box.git"
  },
  "bugs": {
    "url": "https://github.com/ezedike-evan/corridor-in-a-box/issues"
  },
  "homepage": "https://github.com/ezedike-evan/corridor-in-a-box#readme",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "cli": "tsx packages/cli/src/index.ts",
    "example": "tsx examples/run-payment.ts",
    "testnet": "tsx examples/run-testnet.ts",
    "serve": "tsx examples/run-service.ts"
  },
  "dependencies": {
    "@corridor/adapter-kit": "workspace:*",
    "@corridor/engine": "workspace:*",
    "@corridor/manifest": "workspace:*",
    "@corridor/router": "workspace:*",
    "@corridor/sep31": "workspace:*",
    "@corridor/service": "workspace:*",
    "@corridor/stellar": "workspace:*",
    "@corridor/types": "workspace:*"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@stellar/stellar-sdk": "^13.0.0",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.11.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^10.1.8",
    "pg": "^8.13.0",
    "prettier": "^3.4.0",
    "tsx": "^4.23.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.63.0",
    "vitest": "^2.1.0"
  },
  "packageManager": "pnpm@9.12.0"
}
